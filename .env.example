# ════════════════════════════════════════════════════════════════════
# PP-AI  —  Environment Variables
# Copy this file to .env and fill in every value.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
DB_NAME=ppai
DB_USER=ppai
DB_PASSWORD=                        # Required — use a strong random password

# ── JWT ───────────────────────────────────────────────────────────
# Minimum 32 random characters.  Generate: openssl rand -hex 32
JWT_SECRET=                         # Required

# ── Application URL ───────────────────────────────────────────────
# Full URL where the app is accessible (used for OAuth redirects)
FRONTEND_URL=http://localhost:8080

# ── Frontend port (host binding) ──────────────────────────────────
FRONTEND_PORT=8080

# ── Email notifications (optional) ───────────────────────────────
ENABLE_EMAIL=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# ── Google OAuth (optional) ───────────────────────────────────────
# Leave blank to disable Google login entirely.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${FRONTEND_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# ── Keycloak SSO (opcional — arrancar con: make keycloak-up) ─────
# Dejá estas vars vacías para deshabilitar el botón SSO
KEYCLOAK_PUBLIC_URL=http://localhost:8180
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=ppai
KEYCLOAK_CLIENT_ID=ppai-app
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_CALLBACK_URL=http://localhost/api/auth/keycloak/callback

# Admin de Keycloak (solo para el servicio keycloak en docker compose)
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=admin_local_2024
KC_DB_USER=keycloak
KC_DB_PASSWORD=keycloak_local_2024